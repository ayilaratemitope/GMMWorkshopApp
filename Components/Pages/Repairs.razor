@page "/repairs"
@using GMMWorkshopApp.Components.Account.Pages
@using GMMWorkshopApp.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GMMWorkshopApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Repairs</PageTitle>

<h3>Repairs</h3>

<p>View and manage all vehicle repairs recorded in the Workshop.</p>

<p class="text-muted">
    Note: Labour hours are not charged. Motorists are only charged for parts used for repair only.
</p>

<p>
     <a class="btn btn-primary" href="/repairs/create">Add New Repair</a> 
</p>

@if (repairs == null)
{
    <p><em>Loading...</em></p>
}
else if (!repairs.Any())
{
    <p>No repairs are logged yet.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Vehicle</th>
                <th>Owner</th>
                <th>Description</th>
                <th>Labour Hours</th>
                <th>Parts Cost (£)</th>
                <th>Total Charge (£)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var repair in repairs)
            {
                <tr>
                    <td>@repair.RepairDate.ToShortDateString()</td>
                    <td>@repair.Vehicle?.RegistrationNumber</td>
                    <td>@repair.Vehicle?.Motorist?.FullName</td>
                    <td>@repair.RepairDescription</td>
                    <td>@repair.LabourHours.ToString("0.00")</td>
                    <td>@repair.TotalPartsCost.ToString("C")</td>
                    <td>@repair.TotalRepairCost.ToString("C")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary me-1" href="/repairs/edit/@repair.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-secondary" href="/parts/create/@repair.Id">Add Parts</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Repair>? repairs;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        repairs = await context.Repairs
            .Include(r => r.Vehicle)
            .ThenInclude(v => v.Motorist)
            .Include(r => r.Parts)
            .OrderByDescending(r => r.RepairDate)
            .ToListAsync();
    }
}